<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0d1117"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📡 SCANNER DE ALERTAS"
        android:textColor="#2ea043"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="10dp"/>

    <Switch
        android:id="@+id/switchAlertas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Recibir Alertas (En vivo)"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:paddingBottom="15dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#30363d" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/txtAlertas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Esperando oportunidades..."
            android:textColor="#8b949e"
            android:textSize="15sp"
            android:fontFamily="monospace" />
    </ScrollView>
</LinearLayout>